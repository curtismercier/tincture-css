{
  "version": "0.1.0",
  "name": "my-brand/tincture",
  "doc": "Token registry for the Arzadon tenant. Cycle 4 of the Tincture project (proving ground). Cycle 16 extracts the substrate to a standalone package.",
  "axes": {
    "surface": [
      "light",
      "dark"
    ],
    "flavor": [
      "cool",
      "warm",
      "ember"
    ]
  },
  "primitives": {
    "color": {
      "ink-dark": {
        "value": "#1A1612",
        "doc": "Editorial dark ink. WCAG AAA on cream, AA on warm parchment."
      },
      "ink-light": {
        "value": "#FFFFFF",
        "doc": "Always-light ink. Pure white for max contrast on dark surfaces."
      },
      "ink-soft-dark": {
        "value": "#4A4540"
      },
      "ink-soft-light": {
        "value": "#B8B8C4"
      },
      "ink-muted-dark": {
        "value": "#6A655E"
      },
      "ink-muted-light": {
        "value": "#8E91A3"
      },
      "bg-cream": {
        "value": "#F7F4F0",
        "doc": "Page bg, cool flavor."
      },
      "bg-charcoal": {
        "value": "#12151C",
        "doc": "Page bg, dark cool flavor (slate)."
      },
      "bg-parchment-warm": {
        "value": "#1A1A22"
      },
      "bg-warm-charcoal": {
        "value": "#1A1614",
        "doc": "Ember flavor dark surface."
      },
      "bg-card-light": {
        "value": "#FFFFFF"
      },
      "bg-card-dark": {
        "value": "#1A1E28"
      },
      "bg-elev-light": {
        "value": "#EFEAE3",
        "doc": "Slightly raised surface on light."
      },
      "bg-elev-dark": {
        "value": "#242A36"
      },
      "accent-crimson": {
        "value": "#C41E3A",
        "doc": "Strong crimson — cycle 1 light-side accent."
      },
      "accent-vivid": {
        "value": "#E82E11",
        "doc": "Vivid red-orange — cycle 1 dark-side accent."
      },
      "accent-fg": {
        "value": "#FFFFFF",
        "doc": "White ink on saturated accent surface — always."
      },
      "border-accent-tint": {
        "value": "rgba(232, 46, 17, 0.18)",
        "doc": "Accent-vivid (#E82E11) at 18% alpha — dark surface border tint."
      },
      "border-accent-tint-soft": {
        "value": "rgba(232, 46, 17, 0.10)",
        "doc": "Same accent tint at 10% alpha for soft borders."
      },
      "border-ink-tint": {
        "value": "rgba(26, 22, 18, 0.12)",
        "doc": "Ink-tinted border for light surface."
      },
      "border-ink-tint-soft": {
        "value": "rgba(26, 22, 18, 0.06)"
      }
    }
  },
  "semantic": {
    "ink": {
      "id": "ink",
      "type": "color",
      "doc": "Primary text color. Surface-aware via light-dark().",
      "role": "text-primary",
      "lightValue": "{primitives.color.ink-dark}",
      "darkValue": "{primitives.color.ink-light}",
      "legacy": [
        "--color-text-primary",
        "--color-text-on-light",
        "--color-text-on-dark",
        "--color-text-on-booth",
        "--color-text-on-accent-band"
      ]
    },
    "ink-soft": {
      "id": "ink-soft",
      "type": "color",
      "doc": "Secondary text. Used for body copy, captions.",
      "role": "text-secondary",
      "lightValue": "{primitives.color.ink-soft-dark}",
      "darkValue": "{primitives.color.ink-soft-light}",
      "legacy": [
        "--color-text-secondary"
      ]
    },
    "ink-muted": {
      "id": "ink-muted",
      "type": "color",
      "doc": "Tertiary text. Metadata, timestamps.",
      "role": "text-tertiary",
      "lightValue": "{primitives.color.ink-muted-dark}",
      "darkValue": "{primitives.color.ink-muted-light}",
      "legacy": [
        "--color-text-muted"
      ]
    },
    "bg": {
      "id": "bg",
      "type": "color",
      "doc": "Page background. Surface-aware.",
      "role": "surface-page",
      "lightValue": "{primitives.color.bg-cream}",
      "darkValue": "{primitives.color.bg-charcoal}",
      "legacy": [
        "--color-bg-primary"
      ]
    },
    "bg-card": {
      "id": "bg-card",
      "type": "color",
      "doc": "Card / surface block.",
      "role": "surface-card",
      "lightValue": "{primitives.color.bg-card-light}",
      "darkValue": "{primitives.color.bg-card-dark}",
      "legacy": [
        "--color-bg-surface"
      ]
    },
    "bg-elev": {
      "id": "bg-elev",
      "type": "color",
      "doc": "Elevated surface (raised cards, modals, popovers).",
      "role": "surface-elevated",
      "lightValue": "{primitives.color.bg-elev-light}",
      "darkValue": "{primitives.color.bg-elev-dark}",
      "legacy": [
        "--color-bg-elevated"
      ]
    },
    "accent": {
      "id": "accent",
      "type": "color",
      "doc": "Primary accent. Surface-aware: deep crimson on light, vivid red on dark.",
      "role": "accent-primary",
      "lightValue": "{primitives.color.accent-crimson}",
      "darkValue": "{primitives.color.accent-vivid}",
      "contrastPair": "accent-fg",
      "legacy": [
        "--color-accent",
        "--color-accent-gold",
        "--color-accent-warm"
      ]
    },
    "accent-fg": {
      "id": "accent-fg",
      "type": "color",
      "doc": "Ink color on accent surface. Always white. Surface-invariant.",
      "role": "ink-on-accent",
      "lightValue": "{primitives.color.accent-fg}",
      "darkValue": "{primitives.color.accent-fg}",
      "legacy": [
        "--color-accent-fg",
        "--color-text-on-accent",
        "--color-text-on-gold"
      ]
    },
    "accent-warm": {
      "id": "accent-warm",
      "type": "color",
      "doc": "Warm-tier accent. Same as accent today; flavor layer can shift.",
      "role": "accent-warm",
      "lightValue": "{primitives.color.accent-crimson}",
      "darkValue": "{primitives.color.accent-vivid}"
    },
    "border": {
      "id": "border",
      "type": "color",
      "doc": "Default border at low alpha. Ink-tinted on light, accent-tinted on dark (matches the warm glow signature).",
      "role": "border-default",
      "lightValue": "{primitives.color.border-ink-tint}",
      "darkValue": "{primitives.color.border-accent-tint}",
      "legacy": [
        "--color-border-default"
      ]
    },
    "border-soft": {
      "id": "border-soft",
      "type": "color",
      "doc": "Subtle border. Lower alpha of the border tint.",
      "role": "border-subtle",
      "lightValue": "{primitives.color.border-ink-tint-soft}",
      "darkValue": "{primitives.color.border-accent-tint-soft}",
      "legacy": [
        "--color-border-subtle"
      ]
    }
  },
  "flavors": {
    "cool": {
      "doc": "Default flavor. Foundation tokens already represent cool. No overrides.",
      "overrides": {}
    },
    "warm": {
      "doc": "Warmer parchment / charcoal. Maps to legacy 'grey' theme.",
      "overrides": {
        "bg": {
          "lightValue": "#F7F4F0",
          "darkValue": "#1A1A22"
        },
        "bg-card": {
          "lightValue": "#FFFFFF",
          "darkValue": "#22232E"
        },
        "bg-elev": {
          "lightValue": "#EFEAE3",
          "darkValue": "#2A2C38"
        },
        "border": {
          "lightValue": "rgba(48, 30, 20, 0.10)",
          "darkValue": "rgba(232, 100, 60, 0.18)"
        },
        "border-soft": {
          "lightValue": "rgba(48, 30, 20, 0.06)",
          "darkValue": "rgba(232, 100, 60, 0.10)"
        }
      }
    },
    "ember": {
      "doc": "Warm-charcoal palette. Most expressive on dark surface; light side mirrors warm.",
      "overrides": {
        "bg": {
          "lightValue": "#F7F4F0",
          "darkValue": "#1A1614"
        },
        "bg-card": {
          "lightValue": "#FFFFFF",
          "darkValue": "#2A2018"
        },
        "bg-elev": {
          "lightValue": "#EFEAE3",
          "darkValue": "#2D241F"
        },
        "border": {
          "lightValue": "rgba(48, 30, 20, 0.10)",
          "darkValue": "rgba(216, 130, 90, 0.18)"
        },
        "border-soft": {
          "lightValue": "rgba(48, 30, 20, 0.06)",
          "darkValue": "rgba(216, 130, 90, 0.10)"
        },
        "accent": {
          "lightValue": "#C0463A",
          "darkValue": "#E26B47"
        },
        "accent-warm": {
          "lightValue": "#C0463A",
          "darkValue": "#E26B47"
        }
      }
    }
  },
  "components": {
    "Hero": {
      "file": "src/components/Hero.tsx",
      "surfaces": [
        "dark"
      ],
      "doc": "Always-dark feature surface. data-surface=dark via cycle 1.",
      "tokens-read": [
        "accent",
        "accent-fg",
        "bg-card",
        "border",
        "ink",
        "ink-muted",
        "ink-soft"
      ]
    },
    "Pricing": {
      "file": "src/components/Pricing.tsx",
      "surfaces": [
        "light",
        "dark"
      ],
      "doc": "Renders on whatever surface the page provides. 74 token references — most token-dense component in the tenant.",
      "tokens-read": [
        "accent",
        "accent-fg",
        "accent-warm",
        "bg",
        "bg-card",
        "bg-elev",
        "border",
        "border-soft",
        "ink",
        "ink-muted",
        "ink-soft"
      ],
      "groups": [
        "tier-card",
        "comparison-table",
        "feature-list"
      ]
    },
    "ReviewSpotlight": {
      "file": "src/components/reviews/ReviewSpotlight.tsx",
      "surfaces": [
        "dark"
      ],
      "doc": "Always-dark booth-card surface (data-surface=dark). The interior cards inherit dark luminance so var(--ink) auto-flips to light.",
      "tokens-read": [
        "accent",
        "accent-warm",
        "bg-elev",
        "border-soft",
        "ink",
        "ink-muted",
        "ink-soft"
      ]
    }
  }
}
